# Copy to .env for local development.
DEBUG=true
SECRET_KEY=django-insecure-development-only-key
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://postgres:postgres@localhost:5432/feedback
# Where the media pipeline puts the files it is working on: an uploaded meeting
# recording, the audio chunks split out of it. Relative to the checkout root,
# which is where `manage.py` is run from, so this is the `scratch/` directory
# next to this file and `.gitignore` already ignores it. In Compose both `web`
# and `worker` set it to `/scratch`, a volume they share, because the upload is
# written by one and read by the other.
SCRATCH_DIR=scratch
# Transcription. Leave it empty and an uploaded meeting fails with a message
# naming this variable; nothing else in the product uses it. A real key belongs
# in your own .env or in the deployment's environment, never in this file.
OPENAI_API_KEY=
