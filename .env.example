# Copy to .env for local development.
DEBUG=true
SECRET_KEY=django-insecure-development-only-key
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://postgres:postgres@localhost:5432/feedback
# Transcription. Leave it empty and an uploaded meeting fails with a message
# naming this variable; nothing else in the product uses it. A real key belongs
# in your own .env or in the deployment's environment, never in this file.
OPENAI_API_KEY=
